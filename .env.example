# SentinelAI environment template. Copy to .env and fill in.
# APPEND-ONLY: each pillar adds its own keys below its section. Do not edit
# another pillar's section.

# --- Core (Gemini via Vertex AI + ADC) -----------------------------------
# Default auth: Application Default Credentials. No API key — run once:
#   gcloud auth application-default login
#   gcloud config set project <your-project-id>
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# Optional fallback to AI Studio (only if GOOGLE_GENAI_USE_VERTEXAI=false):
# GEMINI_API_KEY=

# --- Pillar modes (sim = fixtures, real = live MCP) ----------------------
SENTINEL_DT_MODE=sim
SENTINEL_GL_MODE=sim
SENTINEL_ARIZE_MODE=sim

# --- P2 Production Sentinel (Dynatrace) ----------------------------------
# Only needed when SENTINEL_DT_MODE=real.
# Use the Platform URL (apps.dynatrace.com), NOT the classic live.dynatrace.com.
DT_ENVIRONMENT=https://YOUR_ENV_ID.apps.dynatrace.com
# Platform Token (dt0s16....) for the MCP reads. Required scopes:
#   app-engine:apps:run          (almost all tools)
#   storage:buckets:read, storage:problems? -> storage:*:read for execute_dql
#   storage:events:write         (send_event)
#   document:documents:write     (create_dynatrace_notebook)
#   app-settings:objects:read    (send_slack_message)
# Without a token the MCP falls back to interactive browser OAuth (local only).
DT_PLATFORM_TOKEN=
# Cap Grail bytes scanned per MCP session (cost control). Default 50.
DT_GRAIL_QUERY_BUDGET_GB=50

# P2-8 self-observability: stream the agent's own OTel traces to Dynatrace.
# OFF unless BOTH are set. Note the .live host (classic), not .apps, for OTLP:
DT_OTLP_ENDPOINT=https://YOUR_ENV_ID.live.dynatrace.com/api/v2/otlp
# Classic Api-Token (dt0c01....) with scope: openTelemetryTrace.ingest
DT_API_TOKEN=
# Resource service.name shown in Dynatrace:
OTEL_SERVICE_NAME=sentinelai

# P2 incident KB + delivery. sim = JSON file + out/briefing.md (offline).
SENTINEL_KB_MODE=sim
SENTINEL_DELIVERY_MODE=sim
# Only needed when SENTINEL_DELIVERY_MODE=real. Real mode prefers the Dynatrace
# MCP send_slack_message tool (set SLACK_CONNECTION_ID + SLACK_CHANNEL, and the
# Slack Connection must exist in the tenant); it falls back to SLACK_WEBHOOK_URL.
SLACK_CONNECTION_ID=
SLACK_CHANNEL=
SLACK_WEBHOOK_URL=

# --- P1 Code Guardian (GitLab) -------------------------------------------
# Only needed when SENTINEL_GL_MODE=real.
# Real path uses the official GitLab MCP server via `npx mcp-remote
# {GITLAB_URL}/api/v4/mcp`. First run opens a browser for OAuth 2.0 Dynamic
# Client Registration; the token caches at ~/.mcp-auth/ and is reused headlessly.
# Prereqs on the GitLab side (gitlab.com Premium/Ultimate or trial):
#   1. Turn on GitLab Duo for the top-level group.
#   2. Enable beta/experimental features for that group.
#   3. Settings > GitLab Duo > Change configuration > "Allow external MCP tools".
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
# Numeric project id (Project > Settings > General > Project ID).
GITLAB_PROJECT_ID=0
# The demo MR iid (e.g. 1 for !1). Used by scripts/probe_gitlab.py and the live
# smoke script; the webhook gateway reads the iid from each event payload.
GITLAB_DEMO_MR_IID=0
# Shared secret GitLab sends as X-Gitlab-Token on the webhook (P1-6). Empty in
# dev lets local POSTs through; production MUST set this.
GITLAB_WEBHOOK_TOKEN=

# --- P3 AI Quality Gate (Arize / Phoenix) --------------------------------
# Only needed when SENTINEL_ARIZE_MODE=real.
PHOENIX_ENDPOINT=
PHOENIX_API_KEY=

# --- D1 Signal store (dashboard cross-pillar stream) ---------------------
# Every pillar's cycle appends its emitted Signal here. sim = JSON shim
# (out/signals.json), real = Firestore (firestore_signals_collection).
SENTINEL_SIGNAL_STORE_MODE=sim

# --- D2 Dashboard API trigger URLs ---------------------------------------
# The dashboard's three "Run X" buttons proxy through services/dashboard_api
# to the matching Cloud Run service. Empty here = local dev returns 503 so
# the frontend can show a clear "not wired" pill. Set at deploy.
DASHBOARD_TRIGGER_GATEWAY_URL=
DASHBOARD_TRIGGER_POLLER_URL=
DASHBOARD_TRIGGER_EVAL_RUNNER_URL=

# --- Team code-review memory (WeMakeDevs / Cognee) -----------------------
# sim = offline JSON shim (out/team_memory.json) + local embeddings (tests).
# real = Cognee Cloud: remember() review findings on merge, recall() on a new PR.
SENTINEL_MEMORY_MODE=sim
# Only needed when SENTINEL_MEMORY_MODE=real. Claim the coupon COGNEE-35 in the
# Cognee Cloud console, then create an API key there.
COGNEE_API_KEY=
# Cognee Cloud tenant URL from the console (e.g. https://<tenant>.aws.cognee.ai).
# Leave blank to run Cognee locally (self-hosted graph) instead of Cloud.
COGNEE_SERVICE_URL=
# Dataset / namespace that scopes this team's memory (remember + recall + forget).
COGNEE_DATASET=sentinel_team_memory
# Cognee points its own LLM/embeddings at Gemini via LLM_PROVIDER/LLM_MODEL/
# LLM_API_KEY — the real adapter sets these from GEMINI_* automatically.
