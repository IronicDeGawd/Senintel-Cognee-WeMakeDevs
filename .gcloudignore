# Anything not needed to run SentinelAI in Cloud Run.

.git/
.gitignore
.gcloudignore

# Local venvs + tooling
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/

# Local-only files
.env
.env.example
out/

# Docs, plan, research — not needed at runtime.
context/
README.md
LICENSE
*.docx
*.md

# Test surface
tests/

# Optional dev scripts (probe + smoke harnesses)
scripts/

# Unrelated workspace artifacts
experiment/

# Frontend tree — the backend image never serves it. dashboard/ is built and
# deployed separately via its own gcloud builds submit (Dockerfile + Next.js
# standalone), so the backend tarball has no reason to carry the 400+ MB of
# node_modules / .next artifacts living here. Without this exclude the
# Cloud Build upload crosses the 500 MB upload limit and 400s.
dashboard/
.playwright-mcp/
