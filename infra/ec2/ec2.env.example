# SentinelAI — single-EC2 deployment env (see infra/ec2/README.md).
# Copy to /home/ubuntu/sentinel/.env and fill in the two secrets.

# --- Core (Gemini via Vertex AI + service account) ------------------------
GOOGLE_GENAI_USE_VERTEXAI=true
# Must be the project the mounted service account belongs to.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_APPLICATION_CREDENTIALS=/home/ubuntu/sentinel/secrets/gcp-sa.json

# AI Studio key. OPTIONAL on EC2: when empty, the Cognee adapter falls back
# to Vertex AI via the service account above (LiteLLM vertex_ai provider).
GEMINI_API_KEY=

# --- Pillar modes (sim = fixtures, real = live MCP) ----------------------
SENTINEL_DT_MODE=sim
SENTINEL_GL_MODE=sim
SENTINEL_ARIZE_MODE=sim
SENTINEL_KB_MODE=sim
SENTINEL_DELIVERY_MODE=sim
SENTINEL_SIGNAL_STORE_MODE=sim

# --- Dashboard triggers — local systemd siblings ---------------------------
DASHBOARD_TRIGGER_GATEWAY_URL=http://127.0.0.1:8101
DASHBOARD_TRIGGER_POLLER_URL=http://127.0.0.1:8102
DASHBOARD_TRIGGER_EVAL_RUNNER_URL=http://127.0.0.1:8103
DASHBOARD_DEMO_DIRECTOR_URL=http://127.0.0.1:8104

# --- Team code-review memory (WeMakeDevs / Cognee) -----------------------
SENTINEL_MEMORY_MODE=real
COGNEE_API_KEY=
# Blank = local embedded Cognee (graph + vectors on this box).
# Set the tenant URL to use Cognee Cloud instead.
COGNEE_SERVICE_URL=
COGNEE_DATASET=sentinel_team_memory
